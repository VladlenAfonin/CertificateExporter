<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CertificateExporter"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="220"
        x:Class="CertificateExporter.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Certificate Exporter"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="False"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        Width="500" Height="150" CanResize="False">

    <Window.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding Export}"></KeyBinding>
    </Window.KeyBindings>

    <Grid Margin="16"
          ColumnDefinitions="Auto,*,Auto"
          RowDefinitions="Auto,*,Auto"
          ShowGridLines="False"
          ColumnSpacing="8">
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                   Text="Regex" />
        <AutoCompleteBox Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                         Text="{Binding InputRegex}"
                         PlaceholderText="Enter certificate regex..."
                         ItemsSource="{Binding CommonRegexes}"
                         FilterMode="Contains"
                         MinimumPrefixLength="1" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"
                 Text="{Binding OutputDir}"
                 PlaceholderText="Select output directory..." />
        <Button Grid.Row="1" Grid.Column="2"
                VerticalAlignment="Center" HorizontalAlignment="Stretch"
                Command="{Binding Browse}" Content="Browse" />

        <Button Grid.Row="2" Grid.Column="2"
                VerticalAlignment="Center" HorizontalAlignment="Stretch"
                Command="{Binding Export}"
                Content="Export" HorizontalContentAlignment="Center" />
    </Grid>

</Window>